# Lokal udvikling: brug Neon (gratis) eller lokal Postgres — ikke file:./dev.db (kun ældre SQLite).
# Eksempel Neon: postgresql://USER:PASSWORD@HOST/DB?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB?sslmode=require"
# Migrationer mod DB ovenfor: kopier denne fil til .env.local og kør «npm run db:migrate» (indlæser .env.local; ren «npx prisma migrate deploy» finder ikke DATABASE_URL uden .env).

# Telnyx Voice / Call Control (valgfri — til Click to call, Predictive, Power Dialer)
# TELNYX_API_KEY=""
# TELNYX_PUBLIC_KEY=""  # til WebRTC client token (når I aktiverer browser-opkald)
# Call Control Application ID fra Telnyx (portal: Application ID — API: connection_id)
# TELNYX_CONNECTION_ID=""
# Alias hvis I foretrækker navnet fra portalen:
# TELNYX_APPLICATION_ID=""
# Telephony Credential ID til browser-WebRTC login_token (POST /v2/telephony_credentials/:id/token)
# TELNYX_TELEPHONY_CREDENTIAL_ID=""
# Udgående numre (CLI) – E.164. For at bruge flere købte numre (typisk 2–4) og fordele belastning:
# sæt KUN TELNYX_FROM_NUMBERS med alle, kommasepareret (ikke kun TELNYX_FROM_NUMBER).
# TELNYX_FROM_NUMBER bruges KUN hvis TELNYX_FROM_NUMBERS er tom = ét nummer for alle opkald.
# TELNYX_FROM_NUMBERS="+4511111111,+4511111112,+4511111113,+4511111114"
# TELNYX_FROM_NUMBER="+4512345678"
# Afsender-nummer til SMS-reminders (møde dagen før, cron). Skal matche et Telnyx-nummer
# med udgående SMS aktiveret — se Messaging i portalen. Fallback hvis tom: TELNYX_FROM_NUMBER.
# TELNYX_SMS_FROM_NUMBER="+4512345678"
# Valgfri: max samtidige udgående opkald (Voice API connection channel limit), fx 8.
# Når sat, begrænser dispatch nye lead-opkald så in-flight outbound-legs ikke overstiger denne værdi.
# TELNYX_OUTBOUND_CHANNEL_LIMIT="8"
# Valgfri: tving webhook pr. opkald — skal matche Call Control-route i appen:
# TELNYX_CALL_WEBHOOK_URL="https://dit-domæne.vercel.app/api/telnyx/webhooks/call-events"
# Vercel Blob (anbefalet): permanente call-recording URL’er — opret Blob store og sæt token
# BLOB_READ_WRITE_TOKEN=""

# Generér med: openssl rand -base64 32
AUTH_SECRET="generer-en-lang-tilfaeldig-streng"

# Ved første seed (npm run db:seed) — skift efter login
SEED_ADMIN_PASSWORD="skift-dette-ved-foerste-koersel"

# Valgfri: fuld URL til dit site (påkrævet korrekt i produktion, fx https://dit-app.vercel.app)
# AUTH_URL="https://dit-app.vercel.app"
# Bruges hvis du vil trigge cron manuelt via Authorization: Bearer <CRON_SECRET>
# CRON_SECRET="lang-hemmelig-streng"

# VIRK CVR API (server-side enrichment)
# Brug Base64-værdien uden "Basic " prefix (gemmes som secret, aldrig i frontend)
# VIRK_API_BASIC_AUTH="xxxxxxxxxxxxxxxx"

# Cal.eu / Cal.com — ekstern booking + Google Meet-link ved mødebooking.
# VIGTIGT om region:
#   - EU (Danmark): brug api.cal.eu — dashboard er app.cal.eu
#   - US:           brug api.cal.com — dashboard er app.cal.com
# En API-nøgle fra app.cal.eu virker IKKE mod api.cal.com (giver 401 Invalid API Key).
# CALCOM_HOST="api.cal.eu"
# API-nøgle fra dashboard → Settings → Developer → API Keys
# CALCOM_API_KEY="cal_live_xxxxxxxx"
# Event Type ID for onboarding-mødet (tal — findes i event type URL/indstillinger)
# CALCOM_EVENT_TYPE_ID="340981"
# Event Type ID for kick-off (Cal.eu sender invitation; onboarding bruger Allio-mail)
# CALCOM_KICKOFF_EVENT_TYPE_ID="342780"
# Webhook-secret: sættes både her OG på webhooken i dashboardet (app.cal.eu → Developer → Webhooks).
# Subscriber URL skal pege på vores app: https://<domæne>/api/webhooks/cal-com
# Triggers: mindst "Booking cancelled" og "Booking rescheduled".
# CALCOM_WEBHOOK_SECRET="lang-hemmelig-streng"

# Podio CRM — kunde-journey, leveringsmodeller, betalingsaftaler.
# Se docs/PODIO-SETUP.md for fuld opsætning (workspace, apps, felter, relationer).
# API-nøgle fra https://podio.com/settings/api:
# PODIO_CLIENT_ID="..."
# PODIO_CLIENT_SECRET="..."
# App-id + app-token (pr. app → ··· → Developer):
# PODIO_KUNDER_APP_ID="..."
# PODIO_KUNDER_APP_TOKEN="..."
# PODIO_MOEDER_APP_ID="..."
# PODIO_MOEDER_APP_TOKEN="..."
# Processer/Leverancer (kanban: ansvarlig + Ikke startet/I gang/Færdig):
# PODIO_PROCESSER_APP_ID="..."
# PODIO_PROCESSER_APP_TOKEN="..."
# PODIO_BETALING_APP_ID="..."
# PODIO_BETALING_APP_TOKEN="..."
# Leveringsmodeller (katalog; opret item "Genaktivering" med external_id "genaktivering"):
# PODIO_LEVERING_APP_ID="..."
# PODIO_LEVERING_APP_TOKEN="..."
# Valgfri: beskytter indgående Podio-webhook (/api/webhooks/podio?token=...)
# PODIO_WEBHOOK_SECRET="lang-tilfaeldig-streng"

# SMTP til udsendelse af mails fra systemet
SMTP_HOST="smtp.simply.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="hej@allio.dk"
SMTP_PASS=""
MAIL_FROM="hej@allio.dk"

# IMAP kopi til "Sendt"-mappe (Simply webmail)
IMAP_HOST="mail.simply.com"
IMAP_PORT="143"
IMAP_SECURE="false"
IMAP_USER="hej@allio.dk"
IMAP_PASS=""
# Evt. "Sendt" hvis din konto bruger dansk mappenavn
IMAP_SENT_MAILBOX="Sent"
